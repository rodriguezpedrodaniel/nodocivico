<?xml version="1.0" encoding="utf-8"?>
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph_dashboard"
    app:startDestination="@id/homeFragment">

    <!-- HOME -->

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.rodriguez.nodocivico.ui.fragments.HomeFragment"
        android:label="Inicio">

        <action
            android:id="@+id/action_homeFragment_to_reportListFragment"
            app:destination="@id/reportListFragment"
            app:enterAnim="@anim/slide_in"/>

        <action
            android:id="@+id/action_homeFragment_to_createReportFragment"
            app:destination="@id/createReportFragment"
            app:enterAnim="@anim/slide_in"/>

        <action
            android:id="@+id/action_homeFragment_to_profileFragment"
            app:destination="@id/profileFragment"
            app:enterAnim="@anim/slide_in"/>

    </fragment>

    <!-- LISTA REPORTES -->

    <fragment
        android:id="@+id/reportListFragment"
        android:name="com.rodriguez.nodocivico.ui.fragments.ReportListFragment"
        android:label="Reportes">

        <action
            android:id="@+id/action_reportListFragment_to_createReportFragment"
            app:destination="@id/createReportFragment"
            app:enterAnim="@anim/slide_in"/>

        <action
            android:id="@+id/action_reportListFragment_to_editarReporteFragment"
            app:destination="@id/editarReporteFragment"
            app:enterAnim="@anim/slide_in"/>

    </fragment>

    <!-- CREAR REPORTE -->

    <fragment
        android:id="@+id/createReportFragment"
        android:name="com.rodriguez.nodocivico.ui.fragments.CrearReporteFragment"
        android:label="Crear Reporte"/>

    <!-- EDITAR REPORTE -->

    <fragment
        android:id="@+id/editarReporteFragment"
        android:name="com.rodriguez.nodocivico.ui.fragments.EditarReporteFragment"
        android:label="Editar Reporte">


        <argument android:name="id"          app:argType="integer"/>
        <argument android:name="apiId"       app:argType="string"/>
        <argument android:name="titulo"      app:argType="string"/>
        <argument android:name="descripcion" app:argType="string"/>
        <argument android:name="ubicacion"   app:argType="string"/>
        <argument android:name="categoria"   app:argType="string"/>
        <argument android:name="estado"      app:argType="string"/>

    </fragment>

    <!-- PERFIL -->

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.rodriguez.nodocivico.ui.fragments.ProfileFragment"
        android:label="Perfil"/>

</navigation>