<?xml version="1.0" encoding="utf-8"?>

<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="12dp"
    android:layout_marginBottom="4dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="6dp"
    app:cardBackgroundColor="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <!-- TITULO -->

        <TextView
            android:id="@+id/txtTitulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hueco en la vía principal"
            android:textColor="@color/text_dark"
            android:textSize="20sp"
            android:textStyle="bold"/>

        <!-- DESCRIPCION -->

        <TextView
            android:id="@+id/txtDescripcion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Existe un hueco grande que afecta el tránsito de vehículos."
            android:textColor="#4B5563"
            android:textSize="14sp"
            android:layout_marginTop="8dp"/>

        <!-- CATEGORIA -->

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#DBEAFE"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:layout_marginTop="14dp">

            <TextView
                android:id="@+id/txtCategoria"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Infraestructura"
                android:textColor="@color/blue_primary"
                android:textStyle="bold"
                android:textSize="13sp"/>

        </LinearLayout>

        <!-- ESTADO -->

        <TextView
            android:id="@+id/txtEstado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Estado: Pendiente"
            android:textColor="#DC2626"
            android:textStyle="bold"
            android:textSize="13sp"
            android:layout_marginTop="12dp"/>

        <!-- BOTONES -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="18dp">

            <!-- EDITAR -->

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Editar"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:backgroundTint="@color/blue_primary"
                app:cornerRadius="12dp"/>

            <!-- ESPACIO -->

            <Space
                android:layout_width="12dp"
                android:layout_height="wrap_content"/>

            <!-- ELIMINAR -->

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEliminar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Eliminar"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:backgroundTint="#DC2626"
                app:cornerRadius="12dp"/>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>